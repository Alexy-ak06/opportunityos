# ── OpportunityOS Environment ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Server
NODE_ENV=development
PORT=4000

# MongoDB (local docker)
MONGO_URI=mongodb://localhost:27017/opportunityos

# Redis (local docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Client
CLIENT_ORIGIN=http://localhost:5173

# Telegram bot (Phase 1.7)
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BRIEFING_TIME=07:30

# Score recompute interval (ms) — default 1 hour
SCORE_RECOMPUTE_INTERVAL_MS=3600000
